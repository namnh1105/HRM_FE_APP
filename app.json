{
  "expo": {
    "name": "Scrolla FE",
    "slug": "scrolla-fe",
    "owner": "ninhhainam12",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "scrolla-fe",
    "userInterfaceStyle": "light",
    "platforms": ["ios", "android", "web"],
    "experiments": {
      "reactCompiler": true
    },
    "splash": { "backgroundColor": "#ffffff" },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.scrolla.fe"
    },
    "android": {
      "adaptiveIcon": { "backgroundColor": "#ffffff" },
      "package": "com.scrolla.fe"
    },
    "web": { "bundler": "metro" },
    "newArchEnabled": true,
    "extra": {
      "apiBaseUrl": "https://scrolla.bitoj.io.vn/api/v1"
    },
    "plugins": [
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Ứng dụng cần quyền truy cập camera để quay video",
          "microphonePermission": "Ứng dụng cần quyền truy cập microphone để ghi âm cho video",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Ứng dụng cần quyền truy cập thư viện ảnh để chọn thumbnail"
        }
      ]
    ]
  }
}
